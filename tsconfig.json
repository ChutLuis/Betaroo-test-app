{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/tokens": ["tokens"],
      "@/tokens/*": ["tokens/*"],
      "@/components/*": ["components/*"],
      "@/atoms/*": ["components/atoms/*"],
      "@/cards/*": ["components/cards/*"],
      "@/select/*": ["components/select/*"],
      "@/mocks/*": ["mocks/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
