{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/tokens": ["tokens"],
      "@/tokens/*": ["tokens/*"],
      "@/components": ["components"],
      "@/components/*": ["components/*"],
      "@/hooks": ["hooks"],
      "@/hooks/*": ["hooks/*"],
      "@/mocks": ["mocks"],
      "@/mocks/*": ["mocks/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": [
    "node_modules",
    ".expo",
    ".claude",
    "recordings",
    "**/__tests__/**"
  ]
}
